{
  "version": 2,
  "installCommand": "pnpm install",
  "buildCommand": "pnpm --filter @workspace/careera run build",
  "outputDirectory": "artifacts/careera/dist/public",
  "functions": {
    "api/index.ts": {
      "runtime": "@vercel/node@3",
      "memory": 512,
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "BASE_PATH": "/",
    "PORT": "3000"
  }
}
